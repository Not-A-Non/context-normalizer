include CHANGELOG.md
include LICENSE
include README.md
include THIRD_PARTY-NOTICES.md
include AGENTS.md
include .github/CODE_OF_CONDUCT.md
include .github/CONTRIBUTING.md
include .github/SECURITY.md
include .github/SUPPORT.md
recursive-include requirements *.json *.lock
recursive-include docs *.md
recursive-include scripts *.cmd *.ps1 *.sh
include scripts/audit_public_tree.py
include scripts/check_public_language.py
include scripts/check_docs.py
include scripts/check_supply_chain_policy.py
include scripts/verify_release.py
recursive-include src/context_normalizer/defaults *.json *.txt *.tsv
recursive-include tests *.py
prune dist
prune build
global-exclude __pycache__ *.py[cod]
