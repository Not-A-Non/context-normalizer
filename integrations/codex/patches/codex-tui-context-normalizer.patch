diff --git a/codex-rs/tui/src/context_normalizer.rs b/codex-rs/tui/src/context_normalizer.rs
new file mode 100644
index 0000000..bc02b19
--- /dev/null
+++ b/codex-rs/tui/src/context_normalizer.rs
@@ -0,0 +1,146 @@
+use std::io::Write;
+use std::path::Path;
+use std::process::Command;
+use std::process::Stdio;
+
+const WORKSPACE_MARKER: &str = ".ctxnorm-workspace.json";
+const MAX_NORMALIZED_BYTES: usize = 4 * 1024 * 1024;
+
+pub(crate) fn is_enabled() -> bool {
+    Path::new(WORKSPACE_MARKER).is_file()
+}
+
+pub(crate) fn normalize_user_text(text: &str) -> Result<String, String> {
+    run(&["bridge", "submit"], text)
+}
+
+pub(crate) fn normalize_display_text(text: &str) -> Result<String, String> {
+    run(&["bridge", "normalize", "--direction", "display"], text)
+}
+
+pub(crate) fn complete_turn() -> Result<(), String> {
+    if !is_enabled() {
+        return Ok(());
+    }
+    let output = Command::new("ctxnorm")
+        .args(["bridge", "complete"])
+        .stdin(Stdio::null())
+        .stdout(Stdio::piped())
+        .stderr(Stdio::piped())
+        .output()
+        .map_err(|error| format!("failed to start ctxnorm: {error}"))?;
+    validate_completion_output(output.status.success(), output.stdout, output.stderr)
+}
+
+fn run(arguments: &[&str], input: &str) -> Result<String, String> {
+    if !is_enabled() || input.is_empty() {
+        return Ok(input.to_string());
+    }
+    let mut child = Command::new("ctxnorm")
+        .args(arguments)
+        .stdin(Stdio::piped())
+        .stdout(Stdio::piped())
+        .stderr(Stdio::piped())
+        .spawn()
+        .map_err(|error| format!("failed to start ctxnorm: {error}"))?;
+    {
+        let mut stdin = child
+            .stdin
+            .take()
+            .ok_or_else(|| "ctxnorm stdin was unavailable".to_string())?;
+        stdin
+            .write_all(input.as_bytes())
+            .map_err(|error| format!("failed to send text to ctxnorm: {error}"))?;
+    }
+    let output = child
+        .wait_with_output()
+        .map_err(|error| format!("failed to read ctxnorm output: {error}"))?;
+    validate_output(input, output.status.success(), output.stdout, output.stderr)
+}
+
+fn validate_completion_output(
+    success: bool,
+    stdout: Vec<u8>,
+    stderr: Vec<u8>,
+) -> Result<(), String> {
+    if !success {
+        let detail = String::from_utf8_lossy(&stderr).trim().to_string();
+        return Err(if detail.is_empty() {
+            "ctxnorm completion was unsuccessful".to_string()
+        } else {
+            detail
+        });
+    }
+    if stdout.len() > MAX_NORMALIZED_BYTES {
+        return Err(format!(
+            "ctxnorm completion output exceeded {MAX_NORMALIZED_BYTES} bytes"
+        ));
+    }
+    Ok(())
+}
+
+fn validate_output(
+    input: &str,
+    success: bool,
+    stdout: Vec<u8>,
+    stderr: Vec<u8>,
+) -> Result<String, String> {
+    if !success {
+        let detail = String::from_utf8_lossy(&stderr).trim().to_string();
+        return Err(if detail.is_empty() {
+            "ctxnorm was unsuccessful".to_string()
+        } else {
+            detail
+        });
+    }
+    if stdout.len() > MAX_NORMALIZED_BYTES {
+        return Err(format!(
+            "ctxnorm output exceeded {MAX_NORMALIZED_BYTES} bytes"
+        ));
+    }
+    let normalized =
+        String::from_utf8(stdout).map_err(|_| "ctxnorm output was not UTF-8".to_string())?;
+    if !input.is_empty() && normalized.is_empty() {
+        return Err("ctxnorm returned empty text".to_string());
+    }
+    if normalized.contains('\0') {
+        return Err("ctxnorm output contained a NUL byte".to_string());
+    }
+    Ok(normalized)
+}
+
+#[cfg(test)]
+mod tests {
+    use super::*;
+
+    #[test]
+    fn accepts_normalized_text() {
+        let normalized = validate_output(
+            "source vocabulary",
+            true,
+            b"normalized vocabulary".to_vec(),
+            Vec::new(),
+        )
+        .expect("normalized text should be accepted");
+        assert_eq!(normalized, "normalized vocabulary");
+    }
+
+    #[test]
+    fn rejects_empty_output_for_nonempty_input() {
+        let error = validate_output("source", true, Vec::new(), Vec::new())
+            .expect_err("empty output must fail closed");
+        assert_eq!(error, "ctxnorm returned empty text");
+    }
+
+    #[test]
+    fn reports_child_failure_without_using_stdout() {
+        let error = validate_output(
+            "source",
+            false,
+            b"unused output".to_vec(),
+            b"invalid vocabulary".to_vec(),
+        )
+        .expect_err("failed child must fail closed");
+        assert_eq!(error, "invalid vocabulary");
+    }
+}
